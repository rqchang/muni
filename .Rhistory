geom_line(size = 1.2) +
geom_point(size = 2) +
scale_y_continuous(labels = scales::percent) +
labs(
x = "Year",
y = "Institutionalization share",
color = "Measure",
title = "Institutionalization of Odd-Lot Municipal Bond Trades"
) +
theme_minimal()
