# ------------------------------------------------- #
# Number of trade and TOTPARAMT
# ------------------------------------------------- #
scale_factor <- max(sum$num_trade, na.rm = TRUE) /
max(sum$totparamt,  na.rm = TRUE)
p3 <- ggplot(sum, aes(x = year)) +
geom_line(
aes(y = num_trade, color = "Number of trades"),
linewidth = 1.2
) +
geom_line(
aes(y = totparamt * scale_factor, color = "Total par traded"),
linewidth = 1.2,
linetype = "dashed"
) +
scale_y_continuous(
name = "Number of trades",
labels = scales::comma,
sec.axis = sec_axis(
~ . / scale_factor,
name = "Total par traded (USD, billions)"
)
) +
scale_x_continuous(
breaks = seq(min(sum$year), max(sum$year), by = 2)
) +
scale_color_manual(
values = c(
"Number of trades" = "steelblue",
"Total par traded" = "darkred"
)
) +
labs(
x = "Year",
y = NULL,
color = NULL
) +
theme_minimal(base_size = 13) +
theme(
panel.background = element_rect(fill = "white", color = NA),
plot.background  = element_rect(fill = "white", color = NA),
axis.line.x      = element_line(color = "black", linewidth = 0.6),
axis.line.y      = element_line(color = "black", linewidth = 0.6),
axis.ticks       = element_line(color = "black"),
panel.grid.major = element_line(color = "grey85"),
panel.grid.minor = element_blank(),
legend.position  = "top"
)
p3
